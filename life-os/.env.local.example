# Supabase (get from https://supabase.com → project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Calendar OAuth (V0 — read-only)
# Create the OAuth client at https://console.cloud.google.com/apis/credentials
# (type: Web application). Authorized redirect URI must match GOOGLE_REDIRECT_URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Token encryption — AES-256-GCM master key for OAuth tokens at rest.
# Generate a fresh value with: openssl rand -base64 32
# Treat this like a database password: rotate it = invalidate all stored tokens.
TOKEN_ENCRYPTION_KEY=
